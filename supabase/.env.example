# =============================================================================
# HexaTech Vault — Supabase Edge Function secrets (example, NO real values).
# Set these with: supabase secrets set KEY=value   (NEVER commit real values)
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected
# automatically by the Supabase runtime for deployed functions — you do not
# need to set them as secrets, but they are listed here for local `supabase
# functions serve --env-file` runs.
# =============================================================================

# --- Supabase (auto-provided in production; needed for local serve) ----------
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google OAuth (company Drive connection) ---------------------------------
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must EXACTLY match the redirect URI registered in the Google OAuth client:
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-PROJECT-REF.functions.supabase.co/drive-oauth-callback

# --- Token encryption (AES-256-GCM key for the refresh token) ----------------
# Provide a 32-byte key. Easiest: a base64 string of 32 random bytes, e.g.
#   openssl rand -base64 32
# Any other string is hashed to 32 bytes (SHA-256) — but a real 32-byte key is
# strongly preferred. This same secret also signs the OAuth `state` (HMAC).
TOKEN_ENCRYPTION_KEY=base64-of-32-random-bytes

# --- Company root folder name (item 03) --------------------------------------
COMPANY_ROOT_NAME=HexaTech Vault

# --- Cron shared secret (item 02) --------------------------------------------
# The hourly pg_cron job sends `Authorization: Bearer <CRON_SECRET>` to
# sync-drive. Must match the value stored via `alter database ... set
# app.cron_secret = '...'` in migration 0003.
CRON_SECRET=a-long-random-cron-secret

# --- Where to send the browser after the OAuth callback ----------------------
# The app URL the callback redirects to (it appends ?drive=connected etc.).
APP_REDIRECT_URL=http://localhost:5173/settings
