# ─────────────────────────────────────────────────────────────────────────────
# HexaTech Vault — Next.js environment
# Copy this file to `.env.local` and fill in the values.
# Defaults: mock backend (no Supabase needed), runs entirely in-browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend selector. "mock" = in-browser localStorage (default). "supabase" = real backend.
NEXT_PUBLIC_BACKEND_MODE=mock

# Display name of the company root folder in the UI.
NEXT_PUBLIC_COMPANY_ROOT_NAME=HexaTech Vault

# ─── Supabase (only needed when NEXT_PUBLIC_BACKEND_MODE=supabase) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Server-only secret (NEVER exposed to the browser) ───
# Used by admin server actions / route handlers that need privileged access.
SUPABASE_SERVICE_ROLE_KEY=
